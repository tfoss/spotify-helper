{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dcg"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(command -v *)",
      "Bash(type *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(tree *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(env *)",
      "Bash(printenv *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln *)",
      "Bash(chmod *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(rm *)",
      "Bash(stat *)",
      "Bash(realpath *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(readlink *)",
      "Bash(id)",
      "Bash(whoami)",
      "Bash(swift *)",
      "Bash(swiftc *)",
      "Bash(swiftlint *)",
      "Bash(swiftformat *)",
      "Bash(xcodebuild *)",
      "Bash(xcode-select *)",
      "Bash(xcrun *)",
      "Bash(simctl *)",
      "Bash(xcresultparser *)",
      "Bash(swift package *)",
      "Bash(swift build *)",
      "Bash(swift test *)",
      "Bash(swift run *)",
      "Bash(plutil *)",
      "Bash(PlistBuddy *)",
      "Bash(/usr/libexec/PlistBuddy *)",
      "Bash(defaults *)",
      "Bash(open *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(brew *)",
      "Bash(mint *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(br *)",
      "Bash(BEADS_DIR=* br *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "Agent"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ./*)",
      "Bash(rm -rf ..)",
      "Bash(rm -rf .git)",
      "Bash(sudo rm -rf *)",
      "Bash(chmod -R 777 /)",
      "Bash(dd if=*of=/dev/*)",
      "Bash(mkfs.*)",
      "Bash(> /dev/sda)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(git reset --hard origin/*)",
      "Bash(pkill -9 *)",
      "Bash(killall *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(halt *)",
      "Bash(init 0)",
      "Bash(init 6)"
    ]
  }
}
