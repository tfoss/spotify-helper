{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "Agent"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ./*)",
      "Bash(rm -rf ..)",
      "Bash(rm -rf .git)",
      "Bash(sudo rm -rf *)",
      "Bash(sudo chmod *)",
      "Bash(sudo chown *)",
      "Bash(chmod -R 777 /)",
      "Bash(chmod -R 777 /*)",
      "Bash(dd if=*of=/dev/*)",
      "Bash(mkfs.*)",
      "Bash(> /dev/sda*)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(git push -f origin main)",
      "Bash(git push -f origin master)",
      "Bash(git reset --hard origin/*)",
      "Bash(git clean -fd *)",
      "Bash(git checkout -- .)",
      "Bash(pkill -9 *)",
      "Bash(killall *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(halt *)",
      "Bash(init 0)",
      "Bash(init 6)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)"
    ]
  }
}
