      "Bash(git push --force origin master)",
      "Bash(git reset --hard origin/*)",
      "Bash(docker system prune -a --force)",
      "Bash(docker rm -f $(docker ps -aq))",
      "Bash(pkill -9 *)",
      "Bash(killall *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(halt *)",
      "Bash(init 0)",
