#!/bin/bash
# swarm-init — Create a new project from the starter template and optionally launch a swarm.
#
# Usage:
#   swarm-init <project-name> [--workers N] [--start]
#
# Examples:
#   swarm-init my-app                    # Create project only
#   swarm-init my-app --start            # Create project and launch swarm (1 lead + 2 workers)
#   swarm-init my-app --workers 4 --start  # Create project and launch with 4 workers

set -euo pipefail

TEMPLATE_REPO="$HOME/code/claude_starting_repo_setup"
CODE_DIR="$HOME/code"
WORKERS=2
START=false
PUBLIC=false

usage() {
    echo "Usage: swarm-init <project-name> [--workers N] [--start]"
    echo ""
    echo "Creates a new project from the starter template."
    echo ""
    echo "Options:"
    echo "  --workers N   Number of worker agents (default: 2)"
    echo "  --start       Launch the swarm immediately after creation"
    echo "  --public      Create a public GitHub repo (default: private)"
    echo "  --help        Show this help"
    exit 1
}

if [ $# -lt 1 ]; then
    usage
fi

PROJECT_NAME="$1"
shift

while [ $# -gt 0 ]; do
    case "$1" in
        --workers)
            WORKERS="$2"
            shift 2
            ;;
        --start)
            START=true
            shift
            ;;
        --public)
            PUBLIC=true
            shift
            ;;
        --help)
            usage
            ;;
        *)
            echo "Unknown option: $1"
            usage
            ;;
    esac
done

PROJECT_DIR="$CODE_DIR/$PROJECT_NAME"

# --- Validate ---

if [ ! -d "$TEMPLATE_REPO" ]; then
    echo "ERROR: Template repo not found at $TEMPLATE_REPO"
    exit 1
fi

if [ -d "$PROJECT_DIR" ]; then
    echo "ERROR: $PROJECT_DIR already exists"
    exit 1
fi

# --- Create project ---

echo "Creating project: $PROJECT_NAME"

git clone "$TEMPLATE_REPO" "$PROJECT_DIR"

cd "$PROJECT_DIR"

# Reset git history — fresh start
rm -rf .git
git init
git add -A
git commit -m "Initial commit from claude_starting_repo_setup template"

# Initialize beads if not already done
if [ ! -f ".beads/metadata.json" ]; then
    br init
    br sync --flush-only
    git add .beads/
    git commit -m "Initialize beads workspace"
fi

# --- Create GitHub repo ---

if command -v gh &>/dev/null; then
    VISIBILITY="--private"
    if [ "$PUBLIC" = true ]; then
        VISIBILITY="--public"
    fi

    # Check if repo already exists on GitHub
    if gh repo view "$PROJECT_NAME" &>/dev/null; then
        echo "GitHub repo $PROJECT_NAME already exists. Setting remote and pushing..."
        REPO_URL=$(gh repo view "$PROJECT_NAME" --json url --jq '.url')
        git -C "$PROJECT_DIR" remote add origin "${REPO_URL}.git" 2>/dev/null || true
        git -C "$PROJECT_DIR" push -u origin main --force
    else
        echo "Creating GitHub repo: $PROJECT_NAME ($VISIBILITY)"
        gh repo create "$PROJECT_NAME" $VISIBILITY --source="$PROJECT_DIR"
        git -C "$PROJECT_DIR" push -u origin main
    fi
    echo "Remote set and pushed."
else
    echo "WARNING: gh not found. Create the remote manually:"
    echo "  gh repo create $PROJECT_NAME --private --source=$PROJECT_DIR --push"
fi

echo ""
echo "Project created: $PROJECT_DIR"
echo ""
echo "Next steps:"
echo "  1. Edit $PROJECT_DIR/PROJECT.md with your project details"
echo "  2. Edit $PROJECT_DIR/CLAUDE.md to customize language/framework specifics"
echo "  3. Launch the swarm: swarm-start $PROJECT_DIR --workers $WORKERS"
echo ""

if [ "$START" = true ]; then
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    exec "$SCRIPT_DIR/swarm-start" "$PROJECT_DIR" --workers "$WORKERS"
fi
