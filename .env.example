# Spotify API credentials
PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Redirect URIs
SPOTIFY_REDIRECT_URI_LOCAL=http://127.0.0.1:5174/auth/callback
SPOTIFY_REDIRECT_URI_PROD=https://your-app.pages.dev/auth/callback

# Auth Worker
PUBLIC_AUTH_WORKER_URL=https://spotify-auth.your-account.workers.dev

# Application
PUBLIC_APP_ENV=local

# Cloudflare Workers
CF_ACCOUNT_ID=
CF_API_TOKEN=

# D1 Database
D1_DATABASE_ID=
D1_DATABASE_NAME=
