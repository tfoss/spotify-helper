# ============================================================
# Frontend / SvelteKit (Cloudflare Pages environment variables)
# Set these in the Cloudflare Pages dashboard or in .env.local
# ============================================================

# Your Spotify app Client ID (safe to expose in the frontend)
PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Deployed Cloudflare Worker URL for auth proxy
PUBLIC_AUTH_WORKER_URL=https://spotify-auth.your-account.workers.dev

# Spotify OAuth redirect URI for production
# Register this in the Spotify Developer Dashboard
PUBLIC_SPOTIFY_REDIRECT_URI=https://your-app.pages.dev/auth/callback

# Application environment (local | production)
PUBLIC_APP_ENV=local

# ============================================================
# Cloudflare Worker secrets — set via `wrangler secret put`
# NEVER commit these to git. See DEPLOYMENT.md for details.
# ============================================================

# Your Spotify app Client ID (also set as Worker secret for PKCE requests)
# SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Your Spotify app Client Secret — WORKER/SERVER ONLY, never expose to the frontend
# SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# The exact origin of your deployed frontend (e.g. https://your-app.pages.dev)
# The Worker returns 403 for any request whose Origin does not match this value
# ALLOWED_ORIGIN=https://your-app.pages.dev

# ============================================================
# Cloudflare account (optional — wrangler reads these automatically)
# ============================================================
CF_ACCOUNT_ID=
CF_API_TOKEN=
